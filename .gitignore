# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── Virtual Environments ──────────────────────────────────────────────────────
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ── Keep .env.example, never the real .env ────────────────────────────────────
!.env.example

# ── Secrets & Keys ────────────────────────────────────────────────────────────
*.pem
*.key
secrets.yaml
secrets.json

# ── Data & Models ─────────────────────────────────────────────────────────────
# Keep .gitkeep sentinels but ignore actual data files
data/raw/*
data/processed/*
data/cve_cache/*
data/chromadb/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/cve_cache/.gitkeep
!data/chromadb/.gitkeep

# ── Reports & Logs ────────────────────────────────────────────────────────────
reports/*
logs/*
!reports/.gitkeep
!logs/.gitkeep

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ── Type Checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json

# ── IDEs & Editors ────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
\#*\#
.\#*

# Emacs backup/auto-save files
*.~undo-tree~
.dir-locals.el

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Notebooks ─────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
notebooks/*.ipynb

# ── Temporary Analysis Files ──────────────────────────────────────────────────
/tmp/
*.tmp
*.bak
