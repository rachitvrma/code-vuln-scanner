# Copy this file to .env and fill in your values.
# Never commit your actual .env file.

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# Recommended models (in order of preference / hardware requirements):
#   codellama:7b     ~4 GB VRAM / RAM  — fast, good for code
#   deepseek-coder:6.7b  ~4 GB         — very strong on code tasks
#   codellama:13b    ~8 GB             — more accurate, slower
#   llama3.1:8b      ~5 GB             — strong general reasoning
OLLAMA_MODEL=codellama:7b
OLLAMA_TIMEOUT=180

# ── NVD API (optional, but strongly recommended) ──────────────────────────────
# Sign up for a free key at: https://nvd.nist.gov/developers/request-an-api-key
# Without a key: 5 requests / 30 s   →  setup_db.py takes ~10 min
# With a key:   50 requests / 30 s   →  setup_db.py takes ~1 min
NVD_API_KEY=

# ── Scanner Tuning ────────────────────────────────────────────────────────────
TOP_K_CVE=5
TOP_K_CWE=3
CONFIDENCE_THRESHOLD=0.5
MAX_CODE_CHUNK_SIZE=2000

# ── Embedding Model ───────────────────────────────────────────────────────────
# all-MiniLM-L6-v2 is fast and small (~80 MB). Good default.
# For better code understanding use: microsoft/codebert-base (~500 MB)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Skip LLM (useful for CI or quick tests without Ollama) ────────────────────
SKIP_LLM=false
